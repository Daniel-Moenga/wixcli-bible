---
interface Props {
	name: string;
	description: string;
	href: string;
}
const { name, description, href } = Astro.props;
---

<a class="wix-component-card" href={href} target="_blank" rel="noreferrer">
	<span class="wix-component-card__name">{name}</span>
	<span class="wix-component-card__desc">{description}</span>
</a>

<style>
	.wix-component-card {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.75rem 1rem;
		border: 1px solid var(--wcb-border, #E8E5E0);
		border-radius: 8px;
		background: var(--wcb-bg-elevated, #FBFAF8);
		text-decoration: none;
		color: inherit;
		transition: border-color 150ms ease, background 150ms ease;
	}

	.wix-component-card:hover {
		border-color: var(--wcb-border-strong, #D3D1CC);
		background: var(--wcb-panel-strong, #F7F6F3);
	}

	.wix-component-card__name {
		font-family: var(--wcb-font-accent, monospace);
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--wcb-text, #37352F);
	}

	.wix-component-card__desc {
		font-size: 0.8125rem;
		color: var(--wcb-text-muted, #6B6966);
		line-height: 1.45;
	}
</style>
