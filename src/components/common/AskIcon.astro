---
interface Props {
	size?: string;
}
const { size = '1.25rem' } = Astro.props;
---

<span class="ask-icon" style={`--ask-icon-size: ${size};`} aria-hidden="true">
	<svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
		<circle cx="19" cy="19" r="14" fill="#F7F6F3" />
		<circle cx="45" cy="19" r="14" fill="#37352F" />
		<circle cx="19" cy="45" r="14" fill="hsl(153,50%,42%)" />
		<circle cx="45" cy="45" r="14" fill="#FBFAF8" stroke="#D3D1CC" stroke-width="1.5" />
	</svg>
</span>

<style>
	.ask-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: var(--ask-icon-size);
		height: var(--ask-icon-size);
		flex-shrink: 0;
	}
	.ask-icon svg {
		width: 100%;
		height: 100%;
	}
</style>
