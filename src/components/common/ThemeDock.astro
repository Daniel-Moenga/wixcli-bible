---
import Icon from './Icon.astro';
---

<wcb-theme-dock class="theme-dock" data-theme-toggle data-reveal="dock">
	<button type="button" data-theme-option="dark" aria-label="Use dark theme" title="Dark theme">
		<Icon name="moon" size="1rem" />
	</button>
	<button type="button" data-theme-option="light" aria-label="Use light theme" title="Light theme">
		<Icon name="sun" size="1rem" />
	</button>
	<button type="button" data-theme-option="auto" aria-label="Use system theme" title="System theme">
		<Icon name="monitor" size="1rem" />
	</button>
</wcb-theme-dock>

<script is:inline>
	if (!customElements.get('wcb-theme-dock')) {
		class WCBThemeDock extends HTMLElement {
			connectedCallback() {
				if (this.dataset.bound === 'true') return;
				this.dataset.bound = 'true';

				this.querySelectorAll('[data-theme-option]').forEach((button) => {
					button.addEventListener('click', () => {
						window.WCBTheme?.setTheme?.(button.getAttribute('data-theme-option') || 'dark');
					});
				});

				window.WCBTheme?.syncToggles?.();
			}
		}

		customElements.define('wcb-theme-dock', WCBThemeDock);
	}
</script>
