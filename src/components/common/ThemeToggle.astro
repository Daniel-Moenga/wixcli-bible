---
const { compact = false } = Astro.props;
---

<wcb-theme-toggle class:list={['theme-toggle', { compact }]} data-theme-toggle>
	<button type="button" data-theme-option="dark" aria-label="Use dark theme">
		Dark
	</button>
	<button type="button" data-theme-option="light" aria-label="Use light theme">
		Light
	</button>
	<button type="button" data-theme-option="auto" aria-label="Use system theme">
		Auto
	</button>
</wcb-theme-toggle>

<script is:inline>
	if (!customElements.get('wcb-theme-toggle')) {
		class WCBThemeToggle extends HTMLElement {
			connectedCallback() {
				if (this.dataset.bound === 'true') return;
				this.dataset.bound = 'true';
				this.querySelectorAll('[data-theme-option]').forEach((button) => {
					button.addEventListener('click', () => {
						window.WCBTheme?.setTheme?.(button.getAttribute('data-theme-option') || 'dark');
					});
				});
				window.WCBTheme?.syncToggles?.();
			}
		}

		customElements.define('wcb-theme-toggle', WCBThemeToggle);
	}
</script>
