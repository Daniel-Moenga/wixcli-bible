<svg viewBox="0 0 280 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
	<!-- dot grid -->
	<pattern id="guides-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
		<circle cx="10" cy="10" r="0.7" fill="currentColor" opacity="0.15" />
	</pattern>
	<rect width="280" height="160" fill="url(#guides-dots)" />

	<!-- terminal window -->
	<rect x="30" y="20" width="220" height="120" rx="6" stroke="currentColor" stroke-width="1" opacity="0.3" />

	<!-- title bar -->
	<line x1="30" y1="38" x2="250" y2="38" stroke="currentColor" stroke-width="1" opacity="0.15" />
	<circle cx="44" cy="29" r="3" fill="currentColor" opacity="0.2" />
	<circle cx="56" cy="29" r="3" fill="currentColor" opacity="0.2" />
	<circle cx="68" cy="29" r="3" fill="currentColor" opacity="0.2" />

	<!-- command lines -->
	<text x="44" y="56" fill="var(--wcb-brand, #3ecf8e)" font-family="monospace" font-size="9" opacity="0.7">$</text>
	<rect x="56" y="49" width="80" height="6" rx="2" fill="currentColor" opacity="0.15" />

	<text x="44" y="74" fill="var(--wcb-brand, #3ecf8e)" font-family="monospace" font-size="9" opacity="0.7">$</text>
	<rect x="56" y="67" width="110" height="6" rx="2" fill="currentColor" opacity="0.15" />

	<text x="44" y="92" fill="var(--wcb-brand, #3ecf8e)" font-family="monospace" font-size="9" opacity="0.7">$</text>
	<rect x="56" y="85" width="65" height="6" rx="2" fill="currentColor" opacity="0.15" />

	<!-- checkmark -->
	<circle cx="200" cy="108" r="10" stroke="var(--wcb-brand, #3ecf8e)" stroke-width="1.5" fill="none" opacity="0.5" />
	<polyline points="195,108 199,112 207,104" stroke="var(--wcb-brand, #3ecf8e)" stroke-width="1.5" fill="none" opacity="0.5" />

	<!-- plus markers -->
	<text x="26" y="18" fill="currentColor" font-family="monospace" font-size="8" opacity="0.25">+</text>
	<text x="254" y="18" fill="currentColor" font-family="monospace" font-size="8" opacity="0.25">+</text>
</svg>
