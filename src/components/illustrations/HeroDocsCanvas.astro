	}

	.hero-canvas__particle--b {
		animation: heroCanvasFloatB 7.2s ease-in-out infinite;
	}

	.hero-canvas__particle--c {
		animation: heroCanvasFloatA 8.1s ease-in-out infinite reverse;
	}

	@keyframes heroCanvasPulse {
		0%,
		100% {
			transform: scale(1);
			opacity: 0.88;
		}

		50% {
			transform: scale(1.18);
			opacity: 1;
		}
	}

	@keyframes heroCanvasDash {
		from {
			stroke-dashoffset: 0;
		}

		to {
			stroke-dashoffset: -72;
		}
	}

	@keyframes heroCanvasSweep {
		0%,
		100% {
