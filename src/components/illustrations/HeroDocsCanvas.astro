			opacity: 0.14;
		}

		50% {
			transform: translateX(22px);
			opacity: 0.32;
		}
	}

	@keyframes heroCanvasFloatA {
		0%,
		100% {
			transform: translateY(0);
			opacity: 0.46;
		}

		50% {
