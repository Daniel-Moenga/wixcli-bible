<svg viewBox="0 0 280 160" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
	<!-- dot grid -->
	<pattern id="ask-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
		<circle cx="10" cy="10" r="0.7" fill="currentColor" opacity="0.15" />
	</pattern>
	<rect width="280" height="160" fill="url(#ask-dots)" />

	<!-- question bubble -->
	<rect x="30" y="24" width="130" height="48" rx="6" stroke="currentColor" stroke-width="1" opacity="0.3" />
	<rect x="44" y="38" width="70" height="5" rx="2" fill="currentColor" opacity="0.15" />
	<rect x="44" y="50" width="100" height="5" rx="2" fill="currentColor" opacity="0.15" />
	<polygon points="50,72 60,72 55,80" fill="currentColor" opacity="0.12" />

	<!-- answer bubble -->
	<rect x="80" y="86" width="170" height="52" rx="6" stroke="var(--wcb-brand, #3ecf8e)" stroke-width="1" opacity="0.4" />
	<rect x="94" y="100" width="120" height="5" rx="2" fill="currentColor" opacity="0.15" />
	<rect x="94" y="112" width="90" height="5" rx="2" fill="currentColor" opacity="0.15" />
	<rect x="94" y="124" width="60" height="5" rx="2" fill="var(--wcb-brand, #3ecf8e)" opacity="0.2" />

	<!-- citation dots -->
	<circle cx="220" cy="40" r="3" fill="var(--wcb-brand, #3ecf8e)" opacity="0.3" />
	<circle cx="232" cy="40" r="3" fill="var(--wcb-brand, #3ecf8e)" opacity="0.2" />
	<circle cx="244" cy="40" r="3" fill="var(--wcb-brand, #3ecf8e)" opacity="0.1" />

	<!-- connection line -->
	<line x1="55" y1="80" x2="94" y2="100" stroke="currentColor" stroke-width="0.5" opacity="0.15" stroke-dasharray="3 3" />

	<!-- plus markers -->
	<text x="26" y="22" fill="currentColor" font-family="monospace" font-size="8" opacity="0.25">+</text>
	<text x="254" y="145" fill="currentColor" font-family="monospace" font-size="8" opacity="0.25">+</text>
</svg>
