---
import Icon from '../components/common/Icon.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';

export const prerender = true;
---

<MarketingLayout
	title="Page not found"
	description="The page you were looking for does not exist in Wix CLI Bible."
	canonicalPath="/404/"
>
	<section class="page-hero" style="text-align: center; padding-top: 4rem;">
		<img
			src="/doodles/Stuck at Home Imagination.webp"
			alt=""
			width="200"
			height="200"
			style="display: block; margin: 0 auto 1.5rem; filter: sepia(0.08); opacity: 0.85;"
		/>
		<p class="eyebrow">404</p>
		<h1>Lost in the cosmos.</h1>
		<p style="max-width: 28rem; margin: 0 auto;">
			This route drifted into the void. The docs, guides, and changelog are still in orbit.
		</p>
		<div class="button-row" style="margin-top: 1.25rem; justify-content: center;">
			<a class="button" href="/docs/">
				<Icon name="bookOpen" size="0.9rem" />
				Docs
			</a>
			<a class="button-secondary" href="/">
				<Icon name="arrowRight" size="0.9rem" />
				Home
			</a>
		</div>
	</section>

	<section class="game-wrap">
		<canvas id="runner"></canvas>
	</section>
</MarketingLayout>

<style>
	.game-wrap {
		display: flex;
		justify-content: center;
		padding: 0 1rem 4rem;
	}
	#runner {
		width: 100%;
		max-width: 800px;
		height: 300px;
		border-radius: var(--wcb-radius-lg);
		border: 1px solid var(--wcb-border);
		cursor: pointer;
		display: block;
	}
</style>

<script is:inline>
(function () {
	const C = document.getElementById('runner');
	const ctx = C.getContext('2d');
	const DPR = Math.min(window.devicePixelRatio || 1, 2);

	function resize() {
		const r = C.getBoundingClientRect();
		C.width = r.width * DPR;
		C.height = r.height * DPR;
		ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
	}
	resize();
	window.addEventListener('resize', resize);

	const W = () => C.width / DPR;
	const H = () => C.height / DPR;
	const BRAND = '#36995F';
	const DOT_COLOR = '#D3D1CC';
	const OBSTACLE_COLOR = '#9B9A97';
	const BG = '#FBFAF8';
	const TEXT_COLOR = '#37352F';
	const GROUND_Y = () => H() - 40;

	const dots = Array.from({ length: 50 }, () => ({
		x: Math.random(), y: Math.random() * 0.75,
		r: Math.random() * 1.0 + 0.3,
		s: Math.random() * 0.3 + 0.1,
		c: Math.random() > 0.5 ? DOT_COLOR : '#E8E5E0',
	}));

	let state = 'idle'; // idle | running | dead
	let score = 0, best = 0, frame = 0, speed = 3;
	let py, vy, onGround;
	const trail = [];
	let obstacles = [];

	function reset() {
		py = GROUND_Y() - 10;
		vy = 0;
		onGround = true;
		score = 0;
		frame = 0;
		speed = 3;
		trail.length = 0;
		obstacles = [];
	}
	reset();

	function jump() {
		if (state === 'idle') { state = 'running'; reset(); return; }
		if (state === 'dead') { state = 'running'; reset(); return; }
		if (onGround) { vy = -8.5; onGround = false; }
	}

	C.addEventListener('pointerdown', jump);
	document.addEventListener('keydown', function (e) {
		if (e.code === 'Space' || e.code === 'ArrowUp') { e.preventDefault(); jump(); }
	});

	function spawnObstacle() {
		const w = W();
		const sz = Math.random() * 10 + 10;
		const sides = Math.floor(Math.random() * 3) + 5;
		obstacles.push({ x: w + 20, sz, sides, passed: false });
	}

	function drawDots() {
		const w = W(), h = H();
		for (const d of dots) {
			d.x -= d.s * 0.001 * speed;
			if (d.x < 0) d.x += 1;
			ctx.fillStyle = d.c;
			ctx.globalAlpha = 0.4 + Math.sin(frame * 0.02 + d.r * 10) * 0.2;
			ctx.beginPath();
			ctx.arc(d.x * w, d.y * h, d.r, 0, Math.PI * 2);
			ctx.fill();
		}
		ctx.globalAlpha = 1;
	}

	function drawGround() {
		const gy = GROUND_Y();
		ctx.strokeStyle = 'rgba(55,53,47,0.08)';
		ctx.lineWidth = 1;
		ctx.setLineDash([4, 4]);
		ctx.beginPath();
		ctx.moveTo(0, gy + 10);
		ctx.lineTo(W(), gy + 10);
		ctx.stroke();
		ctx.setLineDash([]);
	}

	function drawTrail() {
		for (let i = 0; i < trail.length; i++) {
			const t = trail[i];
			const a = t.a * (i / trail.length);
			ctx.fillStyle = BRAND;
			ctx.globalAlpha = a;
			ctx.beginPath();
			ctx.arc(t.x, t.y, t.r, 0, Math.PI * 2);
			ctx.fill();
		}
		ctx.globalAlpha = 1;
	}

	function drawPlayer(px) {
		ctx.fillStyle = BRAND;
		ctx.beginPath();
		ctx.arc(px, py, 10, 0, Math.PI * 2);
		ctx.fill();
	}

	function drawObstacles() {
		for (const o of obstacles) {
			ctx.fillStyle = OBSTACLE_COLOR;
			ctx.beginPath();
			for (let i = 0; i < o.sides; i++) {
				const ang = (Math.PI * 2 / o.sides) * i - Math.PI / 2;
				const ox = o.x + Math.cos(ang) * o.sz * 0.5;
				const oy = GROUND_Y() - o.sz * 0.45 + Math.sin(ang) * o.sz * 0.5;
				i === 0 ? ctx.moveTo(ox, oy) : ctx.lineTo(ox, oy);
			}
			ctx.closePath();
			ctx.fill();
		}
	}

	function drawScore() {
		ctx.fillStyle = TEXT_COLOR;
		ctx.font = '600 14px "JetBrains Mono", monospace';
		ctx.textAlign = 'right';
		ctx.fillText(String(score).padStart(5, '0'), W() - 16, 28);
		if (best > 0) {
			ctx.fillStyle = 'rgba(55,53,47,0.35)';
			ctx.font = '500 10px "JetBrains Mono", monospace';
			ctx.fillText('HI ' + String(best).padStart(5, '0'), W() - 16, 44);
		}
	}

	function drawPrompt(text) {
		ctx.fillStyle = TEXT_COLOR;
		ctx.font = '500 14px "JetBrains Mono", monospace';
		ctx.textAlign = 'center';
		ctx.globalAlpha = 0.5 + Math.sin(frame * 0.05) * 0.2;
		ctx.fillText(text, W() / 2, H() / 2 + 4);
		ctx.globalAlpha = 1;
	}

	const PX = 60;

	function tick() {
		const w = W(), h = H();
		ctx.clearRect(0, 0, w, h);
		ctx.fillStyle = BG;
		ctx.fillRect(0, 0, w, h);

		drawDots();
		drawGround();

		if (state === 'running') {
			frame++;
			speed = 3 + frame * 0.002;
			vy += 0.45;
			py += vy;
			const gy = GROUND_Y() - 10;
			if (py >= gy) { py = gy; vy = 0; onGround = true; }

			trail.push({ x: PX, y: py, r: 5, a: 0.35 });
			if (trail.length > 18) trail.shift();
			for (const t of trail) { t.x -= speed * 0.4; t.a *= 0.94; }

			if (frame % Math.max(40, 90 - Math.floor(frame / 60)) === 0) spawnObstacle();
			for (const o of obstacles) {
				o.x -= speed;
				if (!o.passed && o.x + o.sz * 0.5 < PX) { o.passed = true; score++; }
				const dx = PX - o.x, dy = py - (GROUND_Y() - o.sz * 0.45);
				if (Math.sqrt(dx * dx + dy * dy) < 10 + o.sz * 0.38) {
					state = 'dead';
					if (score > best) best = score;
				}
			}
			obstacles = obstacles.filter(o => o.x > -30);
		} else {
			frame++;
		}

		drawTrail();
		drawPlayer(PX);
		drawObstacles();
		drawScore();

		if (state === 'idle') drawPrompt('Tap to play  ·  Press Space');
		if (state === 'dead') drawPrompt('Score: ' + score + '  ·  Tap to retry');

		requestAnimationFrame(tick);
	}
	tick();
})();
</script>
