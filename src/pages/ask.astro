---
import Icon from '../components/common/Icon.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';

export const prerender = true;

const starterPrompts = [
	{
		label: 'Preview vs release',
		prompt: 'Why can preview pass while release still fails for a Wix CLI app?',
		icon: 'workflow',
	},
	{
		label: 'Surface boundaries',
		prompt: 'How do I decide between dashboard, site, and backend surfaces in Wix CLI?',
		icon: 'layers',
	},
	{
		label: 'Widgets vs scripts',
		prompt: 'When should I build a site widget instead of an embedded script?',
		icon: 'puzzle',
	},
	{
		label: 'CLI workflow',
		prompt: 'What is the normal Wix CLI loop from setup to preview and release?',
		icon: 'terminal',
	},
] as const;
---

<MarketingLayout
	title="Ask AI Beta"
	description="Ask questions about the current Wix CLI with answers grounded in the handbook and curated official sources."
	canonicalPath="/ask/"
>
	<section class="section ask-page">
		<div class="ask-chat-shell">
			<header class="ask-chat-header">
				<div class="ask-chat-header__eyebrow">
					<p class="eyebrow">Ask</p>
					<span class="nav-badge nav-badge--inline">Beta</span>
				</div>
				<h1>Grounded answers for the current Wix CLI.</h1>
				<p>
					Ask workflow, surface, preview, release, or extension questions. Every answer stays grounded
					in the handbook and curated official sources.
				</p>
			</header>

			<div class="ask-chat-stage">
				<div class="ask-chat-thread" data-ask-thread aria-live="polite">
					<div class="ask-empty-state" data-ask-empty>
						<div class="ask-empty-state__panel">
							<img
								src="/doodles/chatting.svg"
								alt=""
								width="140"
								height="140"
								class="ask-empty-state__doodle"
							/>
							<p class="eyebrow">Citations-first chat</p>
							<h2>Ask the handbook anything.</h2>
							<p>
								Use this for workflow confusion, CLI mental-model questions, preview-vs-release
								issues, and surface boundaries.
							</p>
						</div>

						<div class="ask-suggestion-grid">
							{
								starterPrompts.map((item) => (
									<button
										type="button"
										class="ask-suggestion"
										data-ask-suggestion={item.prompt}
										aria-label={`Ask: ${item.prompt}`}
									>
										<span class="ask-suggestion__icon">
											<Icon name={item.icon} size="1rem" />
										</span>
										<span class="ask-suggestion__copy">
											<span class="ask-suggestion__label">{item.label}</span>
											<span class="ask-suggestion__meta">{item.prompt}</span>
										</span>
									</button>
								))
							}
						</div>
					</div>
				</div>

				<form class="ask-composer" data-ask-form>
					<label class="visually-hidden" for="ask-input">Your question</label>
					<textarea
						id="ask-input"
						name="question"
						data-ask-input
						rows="1"
						placeholder="Ask about widgets, preview, release, commands, or surfaces."
					></textarea>

					<div class="ask-composer__footer">
						<p class="ask-composer__hint">
							<Icon name="command" size="0.9rem" />
							Enter to send. Shift + Enter for a line break.
						</p>

						<button class="button" type="submit" data-submit>
							<Icon name="sparkles" size="1rem" />
							Ask the handbook
						</button>
					</div>
				</form>
			</div>
		</div>
	</section>

	<script is:inline>
		const form = document.querySelector('[data-ask-form]');
		const input = document.querySelector('[data-ask-input]');
		const thread = document.querySelector('[data-ask-thread]');
		const emptyState = document.querySelector('[data-ask-empty]');
		const submitButton = document.querySelector('[data-submit]');
		const suggestionButtons = document.querySelectorAll('[data-ask-suggestion]');
		const messages = [];
		let isSubmitting = false;
		const submitLabel = submitButton?.innerHTML;

		const ensureEmptyStateRemoved = () => {
			if (emptyState && emptyState.isConnected) emptyState.remove();
		};

		const scrollThreadToBottom = () => {
			if (!thread) return;
			thread.scrollTo({
				top: thread.scrollHeight,
				behavior: 'smooth',
			});
		};

		const autoResize = () => {
			if (!(input instanceof HTMLTextAreaElement)) return;
			input.style.height = 'auto';
			input.style.height = `${Math.min(input.scrollHeight, 220)}px`;
		};

		const setSubmitting = (nextValue) => {
			isSubmitting = nextValue;
			if (!(input instanceof HTMLTextAreaElement) || !(submitButton instanceof HTMLButtonElement)) return;

			input.disabled = nextValue;
			submitButton.disabled = nextValue;
			submitButton.innerHTML = nextValue ? 'Thinking...' : submitLabel ?? 'Ask the handbook';
		};

		const createMessage = (role, content, options = {}) => {
			const article = document.createElement('article');
			article.className = `ask-message ask-message--${role}`;
			if (options.pending) article.dataset.pending = 'true';

			const bubble = document.createElement('div');
			bubble.className = 'ask-message__bubble';

			const meta = document.createElement('div');
			meta.className = 'ask-message__meta';
			meta.textContent = role === 'assistant' ? 'Wix CLI Bible' : 'You';
			bubble.appendChild(meta);

			const body = document.createElement('div');
			body.className = 'ask-message__body';
			body.textContent = content;
			bubble.appendChild(body);

			if (role === 'assistant' && Array.isArray(options.citations) && options.citations.length > 0) {
				const citations = document.createElement('div');
				citations.className = 'ask-message__citations';

				options.citations.forEach((citation) => {
					if (!citation?.url || !citation?.title) return;

					const link = document.createElement('a');
					link.className = 'ask-citation';
					link.href = citation.url;
					link.target = '_blank';
					link.rel = 'noreferrer';
					link.textContent = citation.title;
					citations.appendChild(link);
				});

				if (citations.childElementCount > 0) {
					bubble.appendChild(citations);
				}
			}

			if (role === 'assistant' && typeof options.disclaimer === 'string' && options.disclaimer.trim()) {
				const disclaimer = document.createElement('p');
				disclaimer.className = 'ask-message__disclaimer';
				disclaimer.textContent = options.disclaimer;
				bubble.appendChild(disclaimer);
			}

			article.appendChild(bubble);
			return article;
		};

		const submitQuestion = async (question) => {
			if (isSubmitting || !thread) return;

			const nextQuestion = question.trim();
			if (!nextQuestion) return;

			ensureEmptyStateRemoved();
			thread.appendChild(createMessage('user', nextQuestion));
			scrollThreadToBottom();

			messages.push({
				role: 'user',
				content: nextQuestion,
			});

			if (input instanceof HTMLTextAreaElement) {
				input.value = '';
				autoResize();
			}

			setSubmitting(true);

			const pendingMessage = createMessage('assistant', 'Thinking with citations...', { pending: true });
			thread.appendChild(pendingMessage);
			scrollThreadToBottom();

			try {
				const response = await fetch('/api/ask', {
					method: 'POST',
					headers: { 'content-type': 'application/json' },
					body: JSON.stringify({
						question: nextQuestion,
						messages,
					}),
				});

				const data = await response.json();
				const answer =
					typeof data?.answer === 'string' && data.answer.trim().length > 0
						? data.answer.trim()
						: 'No grounded answer was returned for that question.';

				messages.push({
					role: 'assistant',
					content: answer,
				});

				pendingMessage.replaceWith(
					createMessage('assistant', answer, {
						citations: Array.isArray(data?.citations) ? data.citations : [],
						disclaimer: typeof data?.disclaimer === 'string' ? data.disclaimer : '',
					})
				);
			} catch (error) {
				const fallback =
					'The Ask beta could not complete the request right now. Check the gateway configuration and try again.';

				messages.push({
					role: 'assistant',
					content: fallback,
				});

				pendingMessage.replaceWith(
					createMessage('assistant', fallback, {
						citations: [],
					})
				);
			} finally {
				setSubmitting(false);
				if (input instanceof HTMLTextAreaElement) {
					input.focus();
				}
				scrollThreadToBottom();
			}
		};

		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			if (!(input instanceof HTMLTextAreaElement)) return;
			await submitQuestion(input.value);
		});

		input?.addEventListener('input', autoResize);
		input?.addEventListener('keydown', (event) => {
			if (event.key === 'Enter' && !event.shiftKey) {
				event.preventDefault();
				form?.requestSubmit();
			}
		});

		suggestionButtons.forEach((button) => {
			button.addEventListener('click', async () => {
				const prompt = button.getAttribute('data-ask-suggestion');
				if (!prompt || !(input instanceof HTMLTextAreaElement)) return;

				input.value = prompt;
				autoResize();
				await submitQuestion(prompt);
			});
		});

		autoResize();
	</script>
</MarketingLayout>
