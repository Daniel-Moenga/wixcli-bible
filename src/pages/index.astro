---
import { getCollection } from 'astro:content';
import AskIcon from '../components/common/AskIcon.astro';
import GitHubStarsBadge from '../components/common/GitHubStarsBadge.astro';
import Icon from '../components/common/Icon.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import HeroDocsCanvas from '../components/illustrations/HeroDocsCanvas.astro';
import DocsIllustration from '../components/illustrations/DocsIllustration.astro';
import GuidesIllustration from '../components/illustrations/GuidesIllustration.astro';
import AskIllustration from '../components/illustrations/AskIllustration.astro';
import CommunityIllustration from '../components/illustrations/CommunityIllustration.astro';
import { formatDisplayDate, site } from '../data/site';

export const prerender = true;

const guides = (await getCollection('guides'))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 3);
const changelog = (await getCollection('changelog'))
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
	.slice(0, 3);
---

<MarketingLayout canonicalPath="/" description={site.description}>
	<section class="section landing-hero landing-hero--clean">
		<div class="landing-hero__grid landing-hero__grid--clean">
			<div class="landing-hero__copy landing-hero__copy--clean">
				<span class="pill" data-hero-reveal>
					<Icon name="globe" size="0.85rem" />
					{site.hero.eyebrow}
				</span>
				<h1 data-hero-reveal>{site.hero.title}</h1>
				<p data-hero-reveal>{site.hero.blurb}</p>
				<div class="button-row" data-hero-reveal>
					<a class="button" href="/docs/">
						<Icon name="bookOpen" size="0.9rem" />
						Read the Docs
					</a>
					<a class="button-secondary" href="/guides/">
						<Icon name="terminal" size="0.9rem" />
						Guides
					</a>
				</div>
			</div>

			<div class="hero-visual" data-hero-reveal>
				<HeroDocsCanvas />
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<section class="section">
		<div class="product-grid" data-stagger>
			<a class="product-card grid-plus" href="/docs/" data-reveal="card">
				<div class="product-card__illustration">
					<DocsIllustration />
				</div>
				<div class="feature-icon">
					<Icon name="bookOpen" size="0.9rem" />
				</div>
				<h3>Docs</h3>
				<p>Structured Handbook. Read in order or jump to what you need. 16 pages covering mental models, surfaces, workflow, and architecture.</p>
				<span class="product-card__arrow"><Icon name="arrowRight" size="0.8rem" /></span>
			</a>
			<a class="product-card grid-plus" href="/guides/" data-reveal="card">
				<div class="product-card__illustration">
					<GuidesIllustration />
				</div>
				<div class="feature-icon">
					<Icon name="terminal" size="0.9rem" />
				</div>
				<h3>Guides</h3>
				<p>Step-by-step walkthroughs for real build problems. First app setup, preview vs release, env management, and more.</p>
				<span class="product-card__arrow"><Icon name="arrowRight" size="0.8rem" /></span>
			</a>
			<a class="product-card grid-plus" href="/ask/" data-reveal="card">
				<div class="product-card__illustration">
					<AskIllustration />
				</div>
				<div class="feature-icon ask-icon-wrap">
					<AskIcon size="1.1rem" />
				</div>
				<h3>Ask <span class="nav-badge">Beta</span></h3>
				<p>Grounded answers with citations from the handbook and official Wix sources. Refuses when evidence is weak.</p>
				<span class="product-card__arrow"><Icon name="arrowRight" size="0.8rem" /></span>
			</a>
			<a class="product-card grid-plus" href="/community/" data-reveal="card">
				<div class="product-card__illustration">
					<CommunityIllustration />
				</div>
				<div class="feature-icon">
					<Icon name="layers" size="0.9rem" />
				</div>
				<h3>Community</h3>
				<p>Design patterns, CLI skills, and showcase entries contributed by developers building with the Wix CLI.</p>
				<span class="product-card__arrow"><Icon name="arrowRight" size="0.8rem" /></span>
			</a>
		</div>
	</section>

	<div class="section-line"></div>

	<section class="section">
		<p class="eyebrow">What We Clarify</p>
		<h2>Things the Official Docs Leave Ambiguous.</h2>
		<p style="color: var(--wcb-text-muted); max-width: 40rem; margin-bottom: 1.25rem;">
			We're not here to criticize Wix -- they built the platform. But some things in the official docs are genuinely confusing. We clarify them so developers don't waste time.
		</p>
		<div class="clarify-grid" data-stagger>
			<div class="clarify-card" data-reveal="card">
				<div class="feature-icon">
					<Icon name="alertTriangle" size="0.85rem" />
				</div>
				<h3>Three CLIs, One Name</h3>
				<p>The unified CLI, legacy CLI for Apps, and CLI for Sites all exist under "Wix CLI." We map which is which so you read the right docs.</p>
			</div>
			<div class="clarify-card" data-reveal="card">
				<div class="feature-icon">
					<Icon name="alertTriangle" size="0.85rem" />
				</div>
				<h3>Preview vs Release</h3>
				<p>The official docs mention this, but it's easy to miss. Some extensions don't work until you <code>release</code> -- not just <code>preview</code>.</p>
			</div>
			<div class="clarify-card" data-reveal="card">
				<div class="feature-icon">
					<Icon name="alertTriangle" size="0.85rem" />
				</div>
				<h3>Registry File Naming</h3>
				<p>The official project structure diagram shows <code>extension.ts</code> but the actual file is <code>extensions.ts</code> (plural). Small typo, real confusion.</p>
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<section class="section workflow-section">
		<p class="eyebrow">The Workflow</p>
		<h2>Built Around the Real Wix CLI Loop.</h2>
		<p style="color: var(--wcb-text-muted); max-width: 40rem; margin-bottom: 1.5rem;">
			This handbook is structured around the actual development workflow. Every page maps to a step in the loop developers follow every day.
		</p>
		<div class="workflow-diagram">
			<svg viewBox="0 0 760 60" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" style="color: var(--wcb-text-soft);">
				<line x1="0" y1="30" x2="760" y2="30" stroke="currentColor" stroke-width="1" opacity="0.15" />

				<circle cx="50" cy="30" r="18" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="50" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">create</text>

				<line x1="68" y1="30" x2="92" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="90,27 96,30 90,33" fill="currentColor" opacity="0.3" />

				<circle cx="115" cy="30" r="18" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="115" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">login</text>

				<line x1="133" y1="30" x2="157" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="155,27 161,30 155,33" fill="currentColor" opacity="0.3" />

				<circle cx="180" cy="30" r="18" stroke="var(--wcb-brand)" stroke-width="1.5" fill="var(--wcb-panel)" />
				<text x="180" y="34" text-anchor="middle" fill="var(--wcb-brand)" font-family="monospace" font-size="7" opacity="0.9">dev</text>

				<line x1="198" y1="30" x2="222" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="220,27 226,30 220,33" fill="currentColor" opacity="0.3" />

				<circle cx="250" cy="30" r="20" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="250" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">generate</text>

				<line x1="270" y1="30" x2="294" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="292,27 298,30 292,33" fill="currentColor" opacity="0.3" />

				<circle cx="320" cy="30" r="18" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="320" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">code</text>

				<line x1="338" y1="30" x2="362" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="360,27 366,30 360,33" fill="currentColor" opacity="0.3" />

				<circle cx="390" cy="30" r="18" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="390" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">build</text>

				<line x1="408" y1="30" x2="432" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="430,27 436,30 430,33" fill="currentColor" opacity="0.3" />

				<circle cx="460" cy="30" r="20" stroke="currentColor" stroke-width="1" fill="var(--wcb-panel)" />
				<text x="460" y="34" text-anchor="middle" fill="currentColor" font-family="monospace" font-size="7" opacity="0.7">preview</text>

				<line x1="480" y1="30" x2="504" y2="30" stroke="currentColor" stroke-width="1" opacity="0.3" />
				<polygon points="502,27 508,30 502,33" fill="currentColor" opacity="0.3" />

				<circle cx="540" cy="30" r="22" stroke="var(--wcb-brand)" stroke-width="1.5" fill="var(--wcb-panel)" />
				<text x="540" y="34" text-anchor="middle" fill="var(--wcb-brand)" font-family="monospace" font-size="7" opacity="0.9">release</text>
			</svg>
		</div>
	</section>

	<div class="section-line"></div>

	<section class="section section--open-source">
		<div class="open-source-block" data-reveal="card">
			<p class="eyebrow">Open-Source</p>
			<h2>Built in the Open. Contributions Welcome.</h2>
			<p>
				Every page, every guide, and every line of code is Open-Source on GitHub. Found a mistake? Know a better way to explain something? Open a PR.
			</p>
			<div class="open-source-block__actions">
				<GitHubStarsBadge />
				<a class="button-secondary" href="/open-source/">
					<Icon name="arrowRight" size="0.85rem" />
					Learn More
				</a>
			</div>
			<div class="open-source-points">
				<div>
					<Icon name="shieldCheck" size="0.85rem" />
					<span>Wix Docs Stay Canonical</span>
				</div>
				<div>
					<Icon name="users" size="0.85rem" />
					<span>Pull Requests Welcome</span>
				</div>
				<div>
					<Icon name="gitBranch" size="0.85rem" />
					<span>MIT + CC BY 4.0</span>
				</div>
			</div>
		</div>
	</section>

	<section class="section home-feed">
		<div class="feed-column">
			<div class="section-heading">
				<p class="eyebrow">Latest Guides</p>
				<h2>Practical Help.</h2>
			</div>
			<div class="collection-grid collection-grid--single">
				{
					guides.map((guide) => (
						<article class="collection-card" data-reveal="card">
							<div class="collection-card__meta">
								<span class="meta-chip">Guide</span>
								<span class="meta-chip">{formatDisplayDate(guide.data.updatedAt)}</span>
							</div>
							<h3>
								<a href={`/guides/${guide.id}/`}>{guide.data.title}</a>
							</h3>
							<p>{guide.data.summary}</p>
						</article>
					))
				}
			</div>
		</div>

		<div class="feed-column">
			<div class="section-heading">
				<p class="eyebrow">Recent Changes</p>
				<h2>What Shipped.</h2>
			</div>
			<div class="changelog-list">
				{
					changelog.map((entry) => (
						<article class="changelog-item" data-reveal="card">
							<div class="changelog-item__meta">
								<span class="meta-chip">{entry.data.type}</span>
								<span class="meta-chip">{formatDisplayDate(entry.data.date)}</span>
							</div>
							<h2>{entry.data.title}</h2>
							<p>{entry.data.summary}</p>
							<a class="changelog-item__link" href={`/changelog/${entry.id}/`}>
								Read Update
								<Icon name="arrowUpRight" size="0.85rem" />
							</a>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<div class="section-line"></div>

	<section class="section cta-section">
		<h2>Start Learning the Wix CLI the Right Way.</h2>
		<p>
			The handbook is free, Open-Source, and structured for developers who want to stop guessing and start building.
		</p>
		<div class="button-row">
			<a class="button" href="/docs/">
				<Icon name="bookOpen" size="0.9rem" />
				Read the Docs
			</a>
			<a class="button-secondary" href="/guides/contributing-a-guide/">
				<Icon name="gitBranch" size="0.85rem" />
				Contribute
			</a>
		</div>
	</section>
</MarketingLayout>
