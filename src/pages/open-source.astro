---
import Icon from '../components/common/Icon.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { site } from '../data/site';

export const prerender = true;
---

<MarketingLayout
	title="Open Source"
	description="Licensing and contribution model for the Wix CLI Bible Open-Source project."
	canonicalPath="/open-source/"
>
	<section class="page-hero">
		<p class="eyebrow">Open-Source</p>
		<h1>Everything Is Open-Source. Contributions Are Welcome.</h1>
		<p>
			The code, the docs, and the design are all on GitHub under permissive licenses. If you find something wrong or want to add something useful, open a PR.
		</p>
	</section>

	<section class="section">
		<div class="legal-grid">
			<article class="legal-card">
				<h3>Code: {site.openSource.codeLicense}</h3>
				<p>Application code, components, and scripts. Use it, fork it, build on it.</p>
			</article>
			<article class="legal-card">
				<h3>Docs: {site.openSource.docsLicense}</h3>
				<p>Handbook content, guides, and documentation. Share with attribution.</p>
			</article>
			<article class="legal-card">
				<h3>Contributions</h3>
				<p>New guides, doc corrections, design patterns, and bug fixes are all welcome. See the Contributing Guide for details.</p>
			</article>
			<article class="legal-card">
				<h3>Source of Truth</h3>
				<p>Wix official docs are canonical. This project is an Open-Source learning companion, not a replacement.</p>
			</article>
		</div>
		<div class="button-row section-actions">
			<a class="button" href={site.repoUrl} target="_blank" rel="noreferrer">
				<Icon name="githubLogo" size="0.9rem" />
				View Source
			</a>
			<a class="button-secondary" href="/guides/contributing-a-guide/">
				<Icon name="arrowRight" size="0.85rem" />
				How to Contribute
			</a>
		</div>
	</section>
</MarketingLayout>
